<?php
require_once '../config.php';

error_reporting(E_ALL);
ini_set('display_errors', 1);

$success = null;
$error = null;

$uploadDir = '../images/produits/';
$uploadDbPath = 'images/produits/';
$allowedExtensions = ['jpg', 'jpeg', 'png', 'webp'];

if (!is_dir($uploadDir)) {
    mkdir($uploadDir, 0777, true);
}

function uploadImageProduit($file, $uploadDir, $uploadDbPath, $allowedExtensions) {
    if (!isset($file) || $file['error'] === UPLOAD_ERR_NO_FILE) {
        return [true, null];
    }
    if ($file['error'] !== UPLOAD_ERR_OK) {
        return [false, "Erreur lors de l'envoi de l'image."];
    }
    $extension = strtolower(pathinfo($file['name'], PATHINFO_EXTENSION));
    if (!in_array($extension, $allowedExtensions, true)) {
        return [false, "Format image invalide."];
    }
    if ($file['size'] > 2 * 1024 * 1024) {
        return [false, "Image trop lourde (max 2 Mo)."];
    }
    $safeName = uniqid('prod_', true) . '.' . $extension;
    $destination = $uploadDir . $safeName;
    if (!move_uploaded_file($file['tmp_name'], $destination)) {
        return [false, "Impossible d'enregistrer l'image."];
    }
    return [true, $uploadDbPath . $safeName];
}

// AJOUT PRODUIT
if (isset($_POST['ajouter'])) {
    $ref = trim($_POST['reference']);
    $nom = trim($_POST['nom']);
    $marque = trim($_POST['marque'] ?? 'Générique'); // ✅ NOUVEAU
    $cat = (int)($_POST['categorie_id'] ?? 0);
    $qte = (int)($_POST['quantite'] ?? 0);
    $seuil = (int)($_POST['seuil_alerte'] ?? 0);
    $prix = (float)($_POST['prix'] ?? 0);

    [$okUpload, $imagePathOrError] = uploadImageProduit($_FILES['image'] ?? null, $uploadDir, $uploadDbPath, $allowedExtensions);

    if (!$okUpload) {
        $error = $imagePathOrError;
    } else {
        $image = $imagePathOrError ?: 'images/produits/no-image.jpg';
        // ✅ SQL mis à jour avec la colonne marque
        $sql = "INSERT INTO produits (reference, nom, marque, categorie_id, quantite, seuil_alerte, prix, image)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?)";
        $stmt = $pdo->prepare($sql);
        $stmt->execute([$ref, $nom, $marque, $cat, $qte, $seuil, $prix, $image]);
        $success = "Produit ajouté !";
    }
}

// ÉDITION
if (isset($_POST['modifier'])) {
    $id = (int)$_POST['id'];
    $ref = trim($_POST['reference']);
    $nom = trim($_POST['nom']);
    $marque = trim($_POST['marque'] ?? 'Générique'); // ✅ NOUVEAU
    $cat = (int)($_POST['categorie_id'] ?? 0);
    $qte = (int)($_POST['quantite'] ?? 0);
    $seuil = (int)($_POST['seuil_alerte'] ?? 0);
    $prix = (float)($_POST['prix'] ?? 0);
    $ancienneImage = $_POST['ancienne_image'] ?? 'images/produits/no-image.jpg';

    $nouvelleImage = $ancienneImage;
    if (isset($_FILES['image']) && $_FILES['image']['error'] !== UPLOAD_ERR_NO_FILE) {
        [$okUpload, $imagePathOrError] = uploadImageProduit($_FILES['image'], $uploadDir, $uploadDbPath, $allowedExtensions);
        if ($okUpload) {
            $nouvelleImage = $imagePathOrError;
            if ($ancienneImage !== 'images/produits/no-image.jpg' && file_exists('../'.$ancienneImage)) {
                @unlink('../'.$ancienneImage);
            }
        } else { $error = $imagePathOrError; }
    }

    if (!$error) {
        // ✅ SQL mis à jour avec la colonne marque
        $sql = "UPDATE produits SET reference=?, nom=?, marque=?, categorie_id=?, quantite=?, seuil_alerte=?, prix=?, image=? WHERE id=?";
        $pdo->prepare($sql)->execute([$ref, $nom, $marque, $cat, $qte, $seuil, $prix, $nouvelleImage, $id]);
        $success = "Produit modifié !";
    }
}

// SUPPRESSION
if (isset($_GET['supprimer'])) {
    $id = (int)$_GET['supprimer'];
    $stmt = $pdo->prepare("SELECT image FROM produits WHERE id = ?");
    $stmt->execute([$id]);
    $p = $stmt->fetch();
    if ($p) {
        $pdo->prepare("DELETE FROM produits WHERE id = ?")->execute([$id]);
        if ($p['image'] !== 'images/produits/no-image.jpg' && file_exists('../'.$p['image'])) {
            @unlink('../'.$p['image']);
        }
        $success = "Produit supprimé !";
    }
}

$produits = $pdo->query("SELECT p.*, c.nom as categorie_nom FROM produits p LEFT JOIN categories c ON p.categorie_id = c.id ORDER BY p.nom")->fetchAll();
$categories = $pdo->query("SELECT * FROM categories ORDER BY nom")->fetchAll();
$edit_produit = null;
if (isset($_GET['edit'])) {
    $stmt = $pdo->prepare("SELECT * FROM produits WHERE id = ?");
    $stmt->execute([(int)$_GET['edit']]);
    $edit_produit = $stmt->fetch();
}
